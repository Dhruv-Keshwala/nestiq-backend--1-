# ──────────────────────────────────────────────
# NESTIQ Backend — Environment Variables
# Copy this file to .env and fill in real values.
# Never commit the actual .env file to git.
# ──────────────────────────────────────────────

# Server
PORT=4000
NODE_ENV=development

# Frontend origin allowed to call this API (CORS).
# If you're opening nestiq-auth.html directly as a file:// URL,
# CORS_ORIGIN can be left as * for local dev only.
CORS_ORIGIN=*

# PostgreSQL connection
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/nestiq

# JWT
JWT_SECRET=change_this_to_a_long_random_string_before_production
JWT_EXPIRES_IN=7d

# Bcrypt cost factor
BCRYPT_SALT_ROUNDS=12

# Login rate limiting (brute-force protection)
LOGIN_RATE_LIMIT_WINDOW_MIN=15
LOGIN_RATE_LIMIT_MAX_ATTEMPTS=5
