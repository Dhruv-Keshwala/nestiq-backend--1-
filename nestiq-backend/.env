# NESTIQ Backend — Environment Variables

# Server
PORT=4000
NODE_ENV=development
CORS_ORIGIN=*

# Database mode: "json" for local dev (zero setup, zero dependencies),
# "postgres" for production (requires `npm install pg` + DATABASE_URL below)
DB_MODE=postgres

# Postgres (only used when DB_MODE=postgres) — matches database.md schema
DATABASE_URL=postgresql://postgres:123456@localhost:5432/Nestiq-db

# JWT
JWT_SECRET=jrepwqlkqejjtpejbbwipsirtjiatnjkdsb
JWT_EXPIRES_IN=7d

# Rate limiting
LOGIN_RATE_LIMIT_WINDOW_MIN=15
LOGIN_RATE_LIMIT_MAX_ATTEMPTS=5

# Bcrypt
BCRYPT_SALT_ROUNDS=12
